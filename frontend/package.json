{
  "name": "unleash-frontend-local",
  "version": "0.0.0",
  "private": true,
  "files": [
    "index.js",
    "build"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "ci": "pnpm run lint:check && pnpm run ts:check && pnpm run build --logLevel=error && pnpm run test --reporter=dot",
    "build": "pnpm run lint:material:icons && vite build",
    "dev": "vite",
    "start": "vite",
    "start:prod": "vite build && vite preview",
    "start:sandbox": "UNLEASH_API=https://sandbox.getunleash.io/ VITE_TEST_REDIRECT=true UNLEASH_BASE_PATH=/pro/ pnpm run start",
    "start:sandbox:enterprise": "UNLEASH_API=https://sandbox.getunleash.io/ VITE_TEST_REDIRECT=true UNLEASH_BASE_PATH=/enterprise/ pnpm run start",
    "start:demo2": "UNLEASH_API=https://sandbox.getunleash.io/ UNLEASH_BASE_PATH=/demo2/ pnpm run start",
    "start:demo": "UNLEASH_BASE_PATH=/demo/ UNLEASH_API=https://app.unleash-hosted.com/ pnpm run start",
    "test": "vitest run",
    "test:snapshot": "pnpm run test -u",
    "test:watch": "vitest watch",
    "lint:material:icons": "./check-imports.rc",
    "lint": "biome lint . --write --error-on-warnings",
    "lint:check": "biome check . --error-on-warnings",
    "fmt": "biome format . --write --error-on-warnings",
    "fmt:check": "biome check . --error-on-warnings",
    "ts:check": "tsc",
    "e2e": "pnpm run e2e:oss",
    "e2e:oss": "pnpm run cypress:run --config baseUrl='http://localhost:4242'  --spec \"cypress/oss/**/*.spec.ts\"",
    "e2e:enterprise": "pnpm run cypress:run --config baseUrl='http://localhost:4242'",
    "e2e:open": "pnpm run cypress:open --config baseUrl='http://localhost:4242'",
    "e2e:dev:open": "pnpm run cypress:open --config baseUrl='http://localhost:3000'",
    "e2e:dev": "pnpm run e2e:dev:oss",
    "e2e:dev:oss": "pnpm run e2e:oss --config baseUrl='http://localhost:3000'",
    "e2e:dev:enterprise": "pnpm run e2e:enterprise --config baseUrl='http://localhost:3000'",
    "e2e:migrations": "cypress run --spec \"cypress/oss/feature/**/*.spec.ts\" --config baseUrl=\"http://localhost:${EXPOSED_PORT:-4242}\" ",
    "cypress:open": "cypress open --e2e --browser electron --env AUTH_USER=admin,AUTH_PASSWORD=unleash4all",
    "cypress:run": "cypress run  --e2e --browser electron --env AUTH_USER=admin,AUTH_PASSWORD=unleash4all",
    "gen:api": "orval --config orval.config.ts",
    "gen:api:demo": "UNLEASH_OPENAPI_URL=https://app.unleash-hosted.com/demo/docs/openapi.json pnpm run gen:api",
    "gen:api:sandbox": "UNLEASH_OPENAPI_URL=https://sandbox.getunleash.io/demo2/docs/openapi.json pnpm run gen:api",
    "gen:api:clean": "pnpm run gen:api && rm -rf src/openapi/apis && sed -i.bak '1q' src/openapi/index.ts && rm src/openapi/index.ts.bak"
  },
